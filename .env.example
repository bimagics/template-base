# Local Development Environment Variables
# Copy this file to .env and replace placeholders with actual values

# GCP Project ID for Vertex AI
GCP_PROJECT_ID={{PROJECT_ID}}

# GCP Region for Vertex AI
VERTEX_LOCATION={{GCP_REGION}}

# Server port (default: 8080)

# API Key for securing the local MCP Server (Auto-generated by WIZBI-CP or set manually for local dev)
MCP_API_KEY={{PROJECT_MCP_API_KEY}}
